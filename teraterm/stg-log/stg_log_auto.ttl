; Tera Term macro: STG log viewer
;
; Start point:
;   1. Open Tera Term manually.
;   2. Use the prefilled host field and log in to the bastion with LDAP.
;   3. After the bastion shell prompt appears, run this macro from
;      Tera Term menu: Control -> Macro.
;
; This macro does not place files on the bastion or app host.
; It only sends commands to the current Tera Term session.

; ===== Values to set only on the company PC =====
APP_HOST = '<H_A>'
RC_USER = 'rcuser'

FRONT_NAMESPACE = '<N_F>'
BACK_NAMESPACE = '<N_B>'

; Used only to narrow down the pod candidate list.
; The user still chooses the exact pod interactively.
FRONT_POD_PATTERN = '<P_F>'
BACK_POD_PATTERN = '<P_B>'

FRONT_LOG_DIR = '<D_F>'
BACK_LOG_DIR = '<D_B>'

FRONT_LOG_GLOB = '<G_F>'
BACK_LOG_GLOB = '<G_B>'

TAIL_LINES = '120'

; ===== Runtime input =====
passwordbox 'LDAP password. Used for SSH from bastion to app host and node.' 'STG log macro'
LDAP_PASS = inputstr
if LDAP_PASS = '' then
    messagebox 'LDAP password is required.' 'STG log macro'
    end
endif

passwordbox 'rcuser password.' 'STG log macro'
RC_PASS = inputstr
if RC_PASS = '' then
    messagebox 'rcuser password is required.' 'STG log macro'
    end
endif

inputbox 'Target: front or back' 'STG log macro' 'front'
TARGET = inputstr
if TARGET = '' then
    TARGET = 'front'
endif

; ===== 0. Sync with the already-open bastion shell =====
; The user has already logged in to the bastion manually.
; Sending an empty line makes the shell print a fresh prompt, which wait can catch.
sendln ''
call wait_shell_prompt

; ===== 1. SSH from bastion to the app-operation host =====
sprintf2 cmd 'ssh %s' APP_HOST
sendln cmd
call handle_ssh_login_with_ldap
call wait_shell_prompt

; ===== 2. Switch to rcuser =====
sprintf2 cmd 'su - %s' RC_USER
sendln cmd
wait 'Password:' 'password:'
sendln RC_PASS
call wait_shell_prompt

; ===== 3. Export settings into the current shell session =====
; These are shell variables only. They are not written to files.
call export_runtime_values
call wait_shell_prompt

; ===== 4. Show pod candidates =====
; This block is sent to "sh" through standard input. Nothing is saved on the server.
sendln 'sh <<''STG_LIST_EOF'''
sendln 'set -eu'
sendln 'case "$TARGET" in'
sendln '  front)'
sendln '    NS="$FRONT_NAMESPACE"'
sendln '    POD_PATTERN="$FRONT_POD_PATTERN"'
sendln '    ;;'
sendln '  back)'
sendln '    NS="$BACK_NAMESPACE"'
sendln '    POD_PATTERN="$BACK_POD_PATTERN"'
sendln '    ;;'
sendln '  *)'
sendln '    echo "TARGET must be front or back: $TARGET" >&2'
sendln '    exit 2'
sendln '    ;;'
sendln 'esac'
sendln 'echo "== target = $TARGET"'
sendln 'echo "== namespace = $NS"'
sendln 'echo "== full pod list"'
sendln 'kubectl get pod -n "$NS" -o wide'
sendln 'echo'
sendln 'echo "== candidate pods"'
sendln 'echo "No.  Pod name  Status  Node"'
sendln 'kubectl get pod -n "$NS" -o wide --no-headers 2>/dev/null | awk -v pat="$POD_PATTERN" ''$1 ~ pat && $3 == "Running" { printf "%2d  %-80s  %-10s  %s\n", ++n, $1, $3, $7 }'''
sendln 'STG_LIST_EOF'
call wait_shell_prompt

; ===== 5. Ask the user which pod to use =====
inputbox 'Pod number, exact pod name, or search keyword. Empty means 1.' 'STG log macro' '1'
POD_SELECT = inputstr
if POD_SELECT = '' then
    POD_SELECT = '1'
endif

sprintf2 cmd 'export POD_SELECT="%s"' POD_SELECT
sendln cmd
call wait_shell_prompt

; ===== 6. Resolve selected pod -> node, then tail the latest log =====
; This is also streamed to sh through standard input. No file is created.
sendln 'sh <<''STG_RUN_EOF'''
sendln 'set -eu'
sendln 'case "$TARGET" in'
sendln '  front)'
sendln '    NS="$FRONT_NAMESPACE"'
sendln '    POD_PATTERN="$FRONT_POD_PATTERN"'
sendln '    LOG_DIR="$FRONT_LOG_DIR"'
sendln '    LOG_GLOB="$FRONT_LOG_GLOB"'
sendln '    ;;'
sendln '  back)'
sendln '    NS="$BACK_NAMESPACE"'
sendln '    POD_PATTERN="$BACK_POD_PATTERN"'
sendln '    LOG_DIR="$BACK_LOG_DIR"'
sendln '    LOG_GLOB="$BACK_LOG_GLOB"'
sendln '    ;;'
sendln '  *)'
sendln '    echo "TARGET must be front or back: $TARGET" >&2'
sendln '    exit 2'
sendln '    ;;'
sendln 'esac'
sendln 'PODS="$(kubectl get pod -n "$NS" -o wide --no-headers 2>/dev/null | awk -v pat="$POD_PATTERN" ''$1 ~ pat && $3 == "Running" { print }'')"'
sendln 'if [ -z "$PODS" ]; then'
sendln '  echo "== no Running pod matched pattern: $POD_PATTERN"'
sendln '  echo "== fallback: all Running pods"'
sendln '  PODS="$(kubectl get pod -n "$NS" -o wide --no-headers 2>/dev/null | awk ''$3 == "Running" { print }'')"'
sendln 'fi'
sendln 'if [ -z "$PODS" ]; then'
sendln '  echo "No Running pod found in namespace: $NS" >&2'
sendln '  exit 3'
sendln 'fi'
sendln 'SELECT="${POD_SELECT:-1}"'
sendln 'case "$SELECT" in'
sendln '  *[!0-9]*)'
sendln '    POD="$(printf "%s\n" "$PODS" | awk -v sel="$SELECT" ''$1 == sel { print $1; found=1; exit } END { if (!found) exit 1 }'' 2>/dev/null || true)"'
sendln '    if [ -z "$POD" ]; then'
sendln '      MATCH_COUNT="$(printf "%s\n" "$PODS" | awk -v sel="$SELECT" ''index($1, sel) > 0 { c++ } END { print c + 0 }'')"'
sendln '      if [ "$MATCH_COUNT" -eq 1 ]; then'
sendln '        POD="$(printf "%s\n" "$PODS" | awk -v sel="$SELECT" ''index($1, sel) > 0 { print $1; exit }'')"'
sendln '      elif [ "$MATCH_COUNT" -gt 1 ]; then'
sendln '        echo "Selection is ambiguous: $SELECT" >&2'
sendln '        printf "%s\n" "$PODS" | awk -v sel="$SELECT" ''index($1, sel) > 0 { printf "%2d  %s\n", NR, $1 }'' >&2'
sendln '        exit 6'
sendln '      else'
sendln '        echo "No pod matched selection: $SELECT" >&2'
sendln '        exit 7'
sendln '      fi'
sendln '    fi'
sendln '    ;;'
sendln '  *)'
sendln '    POD="$(printf "%s\n" "$PODS" | awk -v n="$SELECT" ''NR == n { print $1; exit }'')"'
sendln '    if [ -z "$POD" ]; then'
sendln '      echo "No pod at number: $SELECT" >&2'
sendln '      exit 8'
sendln '    fi'
sendln '    ;;'
sendln 'esac'
sendln 'NODE="$(kubectl get pod -n "$NS" "$POD" -o jsonpath=''{.spec.nodeName}'')"'
sendln 'if [ -z "$NODE" ]; then'
sendln '  echo "Could not resolve node for pod: $POD" >&2'
sendln '  exit 4'
sendln 'fi'
sendln 'echo "== selected pod = $POD"'
sendln 'echo "== selected node = $NODE"'
sendln 'echo "== ssh to node and show logs"'
sendln 'ssh "$NODE" "'
sendln '  cd ''$LOG_DIR'' &&'
sendln '  pwd &&'
sendln '  echo ''== latest log files =='' &&'
sendln '  ls -ltr $LOG_GLOB 2>/dev/null | tail -20 &&'
sendln '  latest=\$(ls -t $LOG_GLOB 2>/dev/null | head -1);'
sendln '  if [ -z \"\$latest\" ]; then'
sendln '    echo ''No .log file found.'' >&2;'
sendln '    exit 5;'
sendln '  fi;'
sendln '  echo;'
sendln '  echo ''== tail =='';'
sendln '  tail -n $TAIL_LINES \"\$latest\"'
sendln '"'
sendln 'STG_RUN_EOF'
call handle_ssh_login_with_ldap

; Leave the terminal open with the log output visible.
end

; ===== Utility: wait until a shell prompt appears =====
:wait_shell_prompt
    wait '$ ' '# ' '> '
return

; ===== Utility: export target-specific settings to the current shell =====
:export_runtime_values
    sprintf2 cmd 'export TARGET="%s"' TARGET
    sendln cmd
    sprintf2 cmd 'export FRONT_NAMESPACE="%s"' FRONT_NAMESPACE
    sendln cmd
    sprintf2 cmd 'export BACK_NAMESPACE="%s"' BACK_NAMESPACE
    sendln cmd
    sprintf2 cmd 'export FRONT_POD_PATTERN="%s"' FRONT_POD_PATTERN
    sendln cmd
    sprintf2 cmd 'export BACK_POD_PATTERN="%s"' BACK_POD_PATTERN
    sendln cmd
    sprintf2 cmd 'export FRONT_LOG_DIR="%s"' FRONT_LOG_DIR
    sendln cmd
    sprintf2 cmd 'export BACK_LOG_DIR="%s"' BACK_LOG_DIR
    sendln cmd
    sprintf2 cmd 'export FRONT_LOG_GLOB="%s"' FRONT_LOG_GLOB
    sendln cmd
    sprintf2 cmd 'export BACK_LOG_GLOB="%s"' BACK_LOG_GLOB
    sendln cmd
    sprintf2 cmd 'export TAIL_LINES="%s"' TAIL_LINES
    sendln cmd
return

; ===== Utility: answer SSH password / first-connect prompts =====
:handle_ssh_login_with_ldap
    while 1
        wait 'continue connecting' 'password:' 'Password:' '$ ' '# ' '> ' 'Permission denied' 'No route to host' 'Could not resolve hostname'
        if result = 1 then
            sendln 'yes'
        elseif result = 2 then
            sendln LDAP_PASS
        elseif result = 3 then
            sendln LDAP_PASS
        elseif result = 4 then
            return
        elseif result = 5 then
            return
        elseif result = 6 then
            return
        elseif result = 7 then
            messagebox 'SSH permission denied.' 'STG log macro'
            end
        elseif result = 8 then
            messagebox 'SSH failed: No route to host.' 'STG log macro'
            end
        elseif result = 9 then
            messagebox 'SSH failed: Could not resolve hostname.' 'STG log macro'
            end
        else
            return
        endif
    endwhile
return
