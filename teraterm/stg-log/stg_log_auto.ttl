; Tera Term macro: STG log viewer
;
; Start point:
;   1. Open Tera Term manually.
;   2. Use the prefilled host field and log in to the bastion with LDAP.
;   3. After the bastion shell prompt appears, run this macro from
;      Tera Term menu: Control -> Macro.
;
; This macro does not place files on the bastion, app host, or node.
; It only sends commands to the current Tera Term session.

; ===== Values to set only on the company PC =====
APP_HOST = '<H_A>'
RC_USER = 'rcuser'

FRONT_NAMESPACE = '<N_F>'
BACK_NAMESPACE = '<N_B>'

FRONT_LOG_DIR = '<D_F>'
BACK_LOG_DIR = '<D_B>'

FRONT_LOG_GLOB = '<G_F>'
BACK_LOG_GLOB = '<G_B>'

TAIL_LINES = '120'

; ===== Runtime input =====
passwordbox 'LDAP password. Used for SSH from bastion to app host and node.' 'STG log macro'
LDAP_PASS = inputstr
if LDAP_PASS = '' then
    messagebox 'LDAP password is required.' 'STG log macro'
    end
endif

passwordbox 'rcuser password.' 'STG log macro'
RC_PASS = inputstr
if RC_PASS = '' then
    messagebox 'rcuser password is required.' 'STG log macro'
    end
endif

inputbox 'Target: front or back' 'STG log macro' 'front'
TARGET = inputstr
if TARGET = '' then
    TARGET = 'front'
endif

; ===== 0. Sync with the already-open bastion shell =====
sendln ''
call wait_shell_prompt

; ===== 1. SSH from bastion to the app-operation host =====
sprintf2 cmd 'ssh %s' APP_HOST
sendln cmd
call handle_ssh_login_with_ldap
call wait_shell_prompt

; ===== 2. Switch to rcuser =====
sprintf2 cmd 'su - %s' RC_USER
sendln cmd
wait 'Password:' 'password:'
sendln RC_PASS
call wait_shell_prompt

; ===== 3. Select front/back fixed values =====
if TARGET = 'front' then
    NAMESPACE = FRONT_NAMESPACE
    LOG_DIR = FRONT_LOG_DIR
    LOG_GLOB = FRONT_LOG_GLOB
elseif TARGET = 'back' then
    NAMESPACE = BACK_NAMESPACE
    LOG_DIR = BACK_LOG_DIR
    LOG_GLOB = BACK_LOG_GLOB
else
    messagebox 'Target must be front or back.' 'STG log macro'
    end
endif

; ===== 4. Show pods and reuse the first Running pod's NODE column =====
sprintf2 cmd 'kubectl get pod -n "%s" -o wide' NAMESPACE
sendln cmd
call wait_shell_prompt

sprintf2 cmd "NODE_NAME=$(kubectl get pod -n %s -o wide --no-headers 2>/dev/null | awk '$3 ~ /^Running$/ { print $7; exit }'); echo NODE_NAME=$NODE_NAME" NAMESPACE
sendln cmd
call wait_shell_prompt

; ===== 5. SSH to the node and show the latest fixed log =====
sendln 'ssh $NODE_NAME'
call handle_ssh_login_with_ldap
call wait_shell_prompt

sprintf2 cmd 'cd "%s"' LOG_DIR
sendln cmd
call wait_shell_prompt

sendln 'pwd'
sprintf2 cmd 'ls -ltr %s 2>/dev/null | tail -20' LOG_GLOB
sendln cmd
call wait_shell_prompt

sprintf2 cmd 'latest=$(ls -t %s 2>/dev/null | head -1); if [ -z "$latest" ]; then echo "No .log file found."; else echo "== tail -n %s $latest =="; tail -n %s "$latest"; fi' LOG_GLOB TAIL_LINES TAIL_LINES
sendln cmd

; Leave the terminal open with the log output visible.
end

; ===== Utility: wait until a shell prompt appears =====
:wait_shell_prompt
    wait '$ ' '# ' '> '
return

; ===== Utility: answer SSH password / first-connect prompts =====
:handle_ssh_login_with_ldap
    while 1
        wait 'continue connecting' 'password:' 'Password:' '$ ' '# ' '> ' 'Permission denied' 'No route to host' 'Could not resolve hostname'
        if result = 1 then
            sendln 'yes'
        elseif result = 2 then
            sendln LDAP_PASS
        elseif result = 3 then
            sendln LDAP_PASS
        elseif result = 4 then
            return
        elseif result = 5 then
            return
        elseif result = 6 then
            return
        elseif result = 7 then
            messagebox 'SSH permission denied.' 'STG log macro'
            end
        elseif result = 8 then
            messagebox 'SSH failed: No route to host.' 'STG log macro'
            end
        elseif result = 9 then
            messagebox 'SSH failed: Could not resolve hostname.' 'STG log macro'
            end
        else
            return
        endif
    endwhile
return
